rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitives
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
              request.auth.token.email == 'snecaj@gmail.com');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.email is string && data.email.size() >= 5 && data.email.size() <= 200 &&
             data.role in ['admin', 'user'] &&
             (data.createdAt is timestamp || data.createdAt is number); // Match what setDoc/serverTimestamp sends
    }

    function isValidPlant(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.category in ['plant', 'mushroom'] &&
             data.scientificName is string && data.scientificName.size() >= 1 && data.scientificName.size() <= 100 &&
             data.isEdible is bool &&
             data.imageUrl is string && data.imageUrl.size() < 1048576 &&
             data.createdAt is number &&
             data.userId == request.auth.uid;
    }

    function isValidSearch(data) {
      return data.query is string && data.query.size() >= 1 && data.query.size() <= 500 &&
             data.category in ['plant', 'mushroom'] &&
             data.result is string && data.result.size() >= 1 && data.result.size() <= 1048576 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1048576)) &&
             data.createdAt is number &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                       isValidUser(incoming()) && 
                       incoming().role == 'user' && // Self-assigned admin blocked
                       incoming().keys().hasAll(['email', 'role', 'createdAt']) &&
                       incoming().keys().size() == 3;
      
      allow update: if (isAdmin() && isValidUser(incoming())) || (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().role == existing().role && // Role cannot be changed by user
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'createdAt']) // Only specified fields
      );

      allow delete: if isAdmin();
    }

    match /plants/{plantId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidPlant(incoming());
      
      allow update: if isSignedIn() && 
                       (isOwner(existing().userId) || isAdmin()) && 
                       isValidPlant(incoming()) &&
                       incoming().userId == existing().userId; // Immutable owner

      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    match /saved_searches/{searchId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidSearch(incoming());
      
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      
      allow update: if false; // Searches are usually immutable in this app
    }
  }
}
